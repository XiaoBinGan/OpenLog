# Ollama (本地 - 无需 API Key)
# OPENAI_API_KEY=sk-dummy
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3

# LM Studio (本地 - 无需 API Key)
# OPENAI_API_KEY=sk-dummy
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_MODEL=local-model

# ============================================
# 日志监控配置
# ============================================
LOG_PATH=
WATCH_FILES=*.log

# 服务器配置
PORT=3001

# 监控刷新间隔（毫秒）
REFRESH_INTERVAL=5000
