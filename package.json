{
  "name": "openlog",
  "version": "1.0.0",
  "description": "智能日志分析与监控系统 - AI-Powered Log Analysis & Monitoring",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --prefix client",
    "server": "node server/index.js",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dockerode": "^4.0.10",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "mysql2": "^3.22.2",
    "node-ssh": "^13.2.1",
    "openai": "^4.28.0",
    "pg": "^8.20.0",
    "systeminformation": "^5.21.24",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
